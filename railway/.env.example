# Railway environment variables (Option A — tapstamp.co)
#
# Supabase Edge Function secrets are WRITE-ONLY — you cannot read them back
# in the dashboard. PASS_CERT/PASS_KEY on Supabase are already set for pass
# generation; you do not need to copy them to Railway unless using cert-based push.

# --- Required ---
SUPABASE_FUNCTIONS_URL=https://biootanbxmqfserzgnxe.supabase.co/functions/v1

# --- Wallet push updates (use your existing APN Auth Key) ---
APN_KEY=-----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----
APN_KEY_ID=your_key_id
APPLE_TEAM_ID=LV69S85DPV
PASS_TYPE_ID=pass.com.tapstamp.loyalty
APNS_PRODUCTION=false

# --- Do NOT put on Railway (Supabase only) ---
# STRIPE_*, SUPABASE_SERVICE_ROLE_KEY, GOOGLE_WALLET_*, JWT_SECRET, EMAIL_*
