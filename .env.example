EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_ORDER_WEBSITE_URL=https://your-order-site.example
# Customer tap/pass base URL (Supabase custom domain or project URL)
# EXPO_PUBLIC_FUNCTIONS_URL=https://api.your-domain.example
# EXPO_PUBLIC_FUNCTIONS_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPPORT_EMAIL=support@your-domain.example

# Dev sign-in (development builds only)
# EXPO_PUBLIC_DEV_EMAIL=your@email.com
# EXPO_PUBLIC_DEV_PASSWORD=yourpassword
# EXPO_PUBLIC_DEV_BOOTSTRAP_SECRET=tapstamp-dev-local
# Supabase secret (must match): supabase secrets set DEV_BOOTSTRAP_SECRET=tapstamp-dev-local

# Edge function secrets
# GOOGLE_WALLET_ISSUER_ID=your_issuer_id
# GOOGLE_WALLET_SERVICE_ACCOUNT=service-account@project.iam.gserviceaccount.com
# GOOGLE_WALLET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# GOOGLE_WALLET_ORIGINS=https://your-project.supabase.co
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_HARDWARE_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_MULTI_PRICE_ID=price_...
# ORDER_WEBSITE_URL=https://your-order-site.example
# FUNCTIONS_PUBLIC_URL=https://api.your-domain.example
